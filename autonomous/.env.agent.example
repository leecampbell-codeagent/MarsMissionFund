# =============================================================================
# Agent Environment Variables
# =============================================================================
# Copy to .env.agent and fill in real values. NEVER commit .env.agent.
# =============================================================================

# --- Authentication (choose ONE) -------------------------------------------

# Option A: Claude Code subscription (Pro/Team/Enterprise)
CLAUDE_CODE_OAUTH_TOKEN=

# Option B: Anthropic API pay-as-you-go
ANTHROPIC_API_KEY=

# --- GitHub (digital twin account) ------------------------------------------

GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
REPO_URL=https://github.com/LeeCampbell/MarsMissionFund
UPSTREAM_REPO=LeeCampbell/MarsMissionFund
BASE_BRANCH=main

# --- Git identity (digital twin — NOT personal) ----------------------------

GIT_AUTHOR_NAME=mmf-agent
GIT_AUTHOR_EMAIL=mmf-agent@example.com
GIT_COMMITTER_NAME=mmf-agent
GIT_COMMITTER_EMAIL=mmf-agent@example.com

# --- Database ---------------------------------------------------------------

DATABASE_URL=postgres://mmf:mmf@postgres:5432/mmf?sslmode=disable

# --- Runtime ----------------------------------------------------------------

WEB_URL=http://localhost:5173
MAX_RUNTIME=43200

# --- Authentication (Clerk) — needed by the dev stack ----------------------

CLERK_PUBLISHABLE_KEY=pk_test_placeholder
CLERK_SECRET_KEY=sk_test_placeholder
VITE_CLERK_PUBLISHABLE_KEY=pk_test_placeholder
CLERK_WEBHOOK_SIGNING_SECRET=whsec_placeholder

# Clerk instance domain for firewall allowlist (derived from publishable key)
CLERK_INSTANCE_DOMAIN=promoted-tiger-9.clerk.accounts.dev
