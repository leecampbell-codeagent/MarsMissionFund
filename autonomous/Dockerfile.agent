# =============================================================================
# MarsMissionFund Autonomous Agent Container
# =============================================================================
# Isolated environment for running Claude Code with --dangerously-skip-permissions.
# Docker is the security boundary — not the permission model.
#
# Writable paths (required for toolchain):
#   /tmp, /workspace, /home/agent/.cache, /home/agent/.npm
# =============================================================================

FROM node:22-bookworm

# ---------------------------------------------------------------------------
# Pinned tool versions — override at build time with --build-arg
# ---------------------------------------------------------------------------
ARG GH_VERSION=2.65.0
ARG DBMATE_VERSION=2.22.0
ARG CLAUDE_CODE_VERSION=latest
ARG BIOME_VERSION=latest
ARG PREK_VERSION=latest
ARG GITLEAKS_VERSION=8.24.3

# ---------------------------------------------------------------------------
# System packages
# ---------------------------------------------------------------------------
RUN apt-get update && apt-get install -y --no-install-recommends \
        iptables \
        ipset \
        dnsutils \
        curl \
        jq \
        sudo \
        postgresql-client \
    && rm -rf /var/lib/apt/lists/*

# ---------------------------------------------------------------------------
# GitHub CLI (pinned .deb)
# ---------------------------------------------------------------------------
RUN ARCH=$(dpkg --print-architecture) \
    && curl -fsSL "https://github.com/cli/cli/releases/download/v${GH_VERSION}/gh_${GH_VERSION}_linux_${ARCH}.deb" \
        -o /tmp/gh.deb \
    && dpkg -i /tmp/gh.deb \
    && rm /tmp/gh.deb

# ---------------------------------------------------------------------------
# dbmate (pinned binary)
# ---------------------------------------------------------------------------
RUN ARCH=$(uname -m) && [ "$ARCH" = "aarch64" ] && ARCH="arm64" || ARCH="amd64" \
    && curl -fsSL "https://github.com/amacneil/dbmate/releases/download/v${DBMATE_VERSION}/dbmate-linux-${ARCH}" \
        -o /usr/local/bin/dbmate \
    && chmod +x /usr/local/bin/dbmate

# ---------------------------------------------------------------------------
# gitleaks (required by prek gitleaks hook)
# ---------------------------------------------------------------------------
RUN ARCH=$(uname -m) && [ "$ARCH" = "aarch64" ] && ARCH="arm64" || ARCH="amd64" \
    && curl -fsSL "https://github.com/gitleaks/gitleaks/releases/download/v${GITLEAKS_VERSION}/gitleaks_${GITLEAKS_VERSION}_linux_${ARCH}.tar.gz" \
        | tar xz -C /usr/local/bin gitleaks \
    && chmod +x /usr/local/bin/gitleaks

# ---------------------------------------------------------------------------
# Global npm tools
# ---------------------------------------------------------------------------
RUN npm install -g \
        "@anthropic-ai/claude-code@${CLAUDE_CODE_VERSION}" \
        "@biomejs/biome@${BIOME_VERSION}" \
        "@j178/prek@${PREK_VERSION}"

# ---------------------------------------------------------------------------
# Playwright (Chromium only — saves ~1 GB vs all browsers)
# ---------------------------------------------------------------------------
RUN npx playwright install --with-deps chromium

# ---------------------------------------------------------------------------
# Non-root agent user
# ---------------------------------------------------------------------------
RUN useradd -m -s /bin/bash agent \
    && mkdir -p /workspace /artifacts /home/agent/.cache /home/agent/.npm \
    && chown -R agent:agent /workspace /artifacts /home/agent \
    && echo "agent ALL=(root) NOPASSWD: /opt/agent/scripts/init-firewall.sh" > /etc/sudoers.d/agent-firewall \
    && chmod 0440 /etc/sudoers.d/agent-firewall

# ---------------------------------------------------------------------------
# Scripts
# ---------------------------------------------------------------------------
COPY scripts/ /opt/agent/scripts/
RUN chmod +x /opt/agent/scripts/*.sh

WORKDIR /workspace
USER agent

ENTRYPOINT ["/opt/agent/scripts/agent-entrypoint.sh"]
