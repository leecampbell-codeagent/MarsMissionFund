{
  "name": "mars-mission-fund",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "docker compose up --build",
    "dev:frontend": "npm run dev --workspace=packages/frontend",
    "dev:backend": "npm run dev --workspace=packages/backend",
    "lint": "eslint . && markdownlint-cli2 '**/*.md' '#node_modules'",
    "lint:fix": "eslint . --fix && prettier --write .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "tsc --noEmit --project packages/backend/tsconfig.json && tsc --noEmit --project packages/frontend/tsconfig.json",
    "test": "npm run test --workspaces --if-present",
    "test:backend": "npm test --workspace=packages/backend",
    "test:frontend": "npm test --workspace=packages/frontend",
    "build": "npm run build --workspaces --if-present"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "eslint": "^9.39.3",
    "markdownlint-cli2": "^0.21.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
